# Google AI / Gemini API key. Keep real values in .env or Vercel only.
GOOGLE_API_KEY=your_google_ai_api_key_here

# Long random value used to sign HttpOnly session cookies.
SESSION_SECRET=replace_with_a_long_random_secret

# Google Apps Script endpoint for visitor validation and admin prototype generation.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/.../exec

# Optional legacy published Google Sheet CSV URL fallback for passkeys.
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/e/.../pub?gid=0&single=true&output=csv

# Admin password for the Project Admin prototype session endpoint.
ADMIN_PASSWORD=your_admin_password_here

# Session and role-specific AI limits.
DEMO_CHAT_LIMIT=5
VISITOR_CHAT_LIMIT=15
ADMIN_CHAT_LIMIT=30
DEMO_SESSION_MAX_AGE=7200
VISITOR_SESSION_MAX_AGE=86400
ADMIN_SESSION_MAX_AGE=3600

# Client-side app settings.
HISTORY_WINDOW_SIZE=30
DEFAULT_CENTER=[3.1495,101.6960]
ZOOM=16
ZOOM_THRESHOLD=18
POLYGON_OPACITY=0.2
MAX_FONT_SIZE=130

# Server-side chat safety and quota settings.
CHAT_MAX_QUERY_CHARS=1000
CHAT_HISTORY_MESSAGES=10
CHAT_HISTORY_TEXT_CHARS=1500
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_MS=3600000
